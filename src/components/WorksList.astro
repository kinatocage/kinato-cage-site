---
import { getWorks } from "../lib/microcms";

// microCMS から作品・事例データを取得
const response = await getWorks({ limit: 12 });
const works = response.contents;
---

<div class="works-grid">
  {works.map((work) => (
    <a href={`/works/${work.id}`} class="work-card">
      <div class="work-card-image-wrapper">
        {work.images && work.images.length > 0 ? (
          <img 
            src={work.images[0].url} 
            alt={work.title} 
            class="work-card-image" 
            loading="lazy"
          />
        ) : (
          <div class="work-card-placeholder">No Image</div>
        )}
      </div>
      <div class="work-card-content">
        <h3 class="work-card-title">{work.title}</h3>
        <div class="work-card-meta">
          <span class="work-card-species">
            {work.seitainame && work.seitainame.length > 0 
              ? work.seitainame.map(s => s.name).join(', ') 
              : '未設定'}
          </span>
          <span class="work-card-size">{work.size}</span>
        </div>
      </div>
    </a>
  ))}
</div>

<style>
  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    padding: 1.5rem;
  }

  .work-card {
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    overflow: hidden;
    background-color: #ffffff;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .work-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .work-card-image-wrapper {
    position: relative;
    aspect-ratio: 4/3;
    width: 100%;
    overflow: hidden;
    background-color: #f7f7f7;
    border-bottom: 1px solid #f1f5f9;
  }

  .work-card-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .work-card-placeholder {
    width: 100%;
    height: 100%;
    background-color: #f8fafc;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
    font-size: 0.875rem;
  }

  .work-card-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .work-card-title {
    margin: 0 0 0.75rem 0;
    font-size: 1.125rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.4;
  }

  .work-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .work-card-species {
    background-color: #e0f2fe;
    color: #0369a1;
    padding: 0.125rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .work-card-size {
    background-color: #f1f5f9;
    color: #475569;
    padding: 0.125rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
  }

</style>
