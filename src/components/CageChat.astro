---
---

<div id="ai-chat-widget" class="fixed bottom-6 right-6 z-[9999] font-sans flex flex-col items-end">
  
  <!-- チャットウィンドウ -->
  <div id="ai-chat-window" class="hidden mb-4 w-80 sm:w-96 h-[550px] max-h-[calc(100vh-120px)] bg-white border border-pink-100 rounded-2xl shadow-2xl flex-col transition-all duration-300 origin-bottom-right overflow-hidden">
    
    <!-- ヘッダー -->
    <div class="chat-header text-white p-4 flex justify-between items-center shadow-sm">
      <div class="flex items-center gap-2.5">
        <!-- アイコン：きなとさんキャラクター画像 -->
        <div class="w-9 h-9 rounded-full overflow-hidden flex-shrink-0 border-2 border-white/50 shadow-sm">
          <img 
            src="/assets/characters/Gemini_Generated_Image_rhw0c8rhw0c8rhw0.png" 
            alt="きなとさん" 
            class="w-full h-full object-cover object-top"
          />
        </div>
        <div>
          <span class="font-bold text-sm tracking-wide block leading-tight">きなとさんとケージ相談</span>
          <span class="text-xs opacity-75 block leading-tight">AI相談窓口（学習が未完のため一般的な回答になります）</span>
        </div>
      </div>
      <button id="ai-chat-close" class="text-white hover:text-pink-100 transition-colors bg-white/20 hover:bg-white/30 rounded-full p-1" aria-label="閉じる">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- メッセージエリア -->
    <div id="ai-chat-messages" class="flex-1 p-4 overflow-y-auto bg-[#FFF8F5] flex flex-col gap-3">
      <!-- 初期メッセージ -->
      <div class="flex items-start gap-2 max-w-[85%]">
        <div class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0 border-2 border-pink-200 shadow-sm mt-1">
          <img 
            src="/assets/characters/Gemini_Generated_Image_rhw0c8rhw0c8rhw0.png" 
            alt="きなとさん" 
            class="w-full h-full object-cover object-top"
          />
        </div>
        <div class="bg-white p-3 rounded-2xl rounded-tl-sm text-sm text-[#5A544F] shadow-sm border border-[#F2E0D8] leading-relaxed">
          こんにちは！飼いたい生き物を教えていただければ、おすすめのケージサイズをご案内します！
        </div>
      </div>
    </div>

    <!-- 考え中インジケーター -->
    <div id="ai-chat-thinking" class="hidden px-4 pb-2 bg-[#FFF8F5]">
      <div class="flex items-center gap-2 text-xs text-[#8A9A86] font-medium bg-[#C1CDC0]/20 py-1.5 px-3 rounded-full w-fit">
        <svg class="animate-spin h-3.5 w-3.5 text-[#8A9A86]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        考え中...
      </div>
    </div>

    <!-- 連携ボタン -->
    <div class="px-3 pb-2 bg-white">
      <button type="button" id="ai-chat-to-contact" class="w-full py-2 text-sm text-[#6B7E66] border border-[#6B7E66] rounded-xl hover:bg-[#6B7E66] hover:text-white transition-colors flex items-center justify-center gap-2">
        <span class="icon">📝</span> この内容で問い合わせフォームへ入力
      </button>
    </div>

    <!-- 入力エリア -->
    <form id="ai-chat-form" class="p-3 bg-white border-t border-[#F2E0D8] flex gap-2 items-end shadow-[0_-4px_10px_-4px_rgba(244,167,185,0.15)]">
      <textarea 
        id="ai-chat-input" 
        rows="1" 
        class="flex-1 resize-none border border-[#F2E0D8] rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#F4A7B9]/50 focus:border-[#F4A7B9] bg-[#FFF8F5] transition-all" 
        placeholder="メッセージを入力..."
        required
      ></textarea>
      <button 
        type="submit" 
        class="chat-send-btn text-white rounded-xl p-2.5 transition-colors shadow-sm focus:ring-2 focus:ring-[#F4A7B9] focus:ring-offset-2 flex-shrink-0"
        aria-label="送信"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform rotate-90" viewBox="0 0 20 20" fill="currentColor">
          <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z" />
        </svg>
      </button>
    </form>
  </div>

  <!-- フローティングボタン（吹き出し＋ボタン） -->
  <div class="flex flex-col items-end gap-2">
    <!-- 「相談はこちら」吹き出し -->
    <div id="chat-callout" class="chat-callout">
      <span>💬 相談はこちら</span>
    </div>
    <button id="ai-chat-toggle" class="chat-toggle-btn text-white rounded-full w-14 h-14 flex items-center justify-center shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 relative group border-2 border-white focus:outline-none focus:ring-4 focus:ring-[#F4A7B9]/40 overflow-hidden">
      <!-- バッジ -->
      <span class="absolute top-0 right-0 block h-3.5 w-3.5 rounded-full bg-red-400 ring-2 ring-white animate-pulse z-10"></span>
      <!-- アイコン：きなとさん顔写真 -->
      <img 
        src="/assets/characters/Gemini_Generated_Image_rhw0c8rhw0c8rhw0.png" 
        alt="きなとさんに相談する" 
        class="w-full h-full object-cover object-top"
      />
    </button>
  </div>
</div>

<style>
  /* チャットのカラーテーマ：サイトのグリーン＋ピンクに合わせる */
  .chat-header {
    background: linear-gradient(135deg, #8A9A86 0%, #7A9E75 50%, #F4A7B9 100%);
  }
  .chat-toggle-btn {
    background: linear-gradient(135deg, #8A9A86 0%, #6B7E66 100%);
  }
  .chat-toggle-btn:hover {
    background: linear-gradient(135deg, #7A9E75 0%, #5e6e5a 100%);
  }
  .chat-send-btn {
    background: linear-gradient(135deg, #F4A7B9 0%, #e8879d 100%);
  }
  .chat-send-btn:hover {
    background: linear-gradient(135deg, #e8879d 0%, #d96f88 100%);
  }
  /* ユーザーメッセージのバブル色もサイトテーマに合わせる */
  .user-bubble {
    background: linear-gradient(135deg, #8A9A86 0%, #6B7E66 100%);
    color: white;
  }

  /* 「相談はこちら」吹き出し */
  .chat-callout {
    background: white;
    border: 2px solid #F4A7B9;
    border-radius: 14px;
    padding: 0.45rem 0.9rem;
    font-size: 0.8rem;
    font-family: 'Kiwi Maru', serif;
    color: #5A544F;
    font-weight: 500;
    box-shadow: 0 4px 16px rgba(244, 167, 185, 0.3);
    position: relative;
    white-space: nowrap;
    animation: callout-bounce 2.5s ease-in-out infinite;
    /* チャット開いてる時は非表示（JSで制御） */
  }
  /* 吹き出しの三角（下向き、右寄り） */
  .chat-callout::after {
    content: '';
    position: absolute;
    bottom: -10px;
    right: 18px;
    border-width: 9px 7px 0 7px;
    border-style: solid;
    border-color: white transparent transparent transparent;
    filter: drop-shadow(0 2px 0 #F4A7B9);
  }
  @keyframes callout-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }
  /* AI回答内のリンク */
  .ai-contact-link {
    color: #6B7E66;
    text-decoration: underline;
    font-weight: 600;
    transition: color 0.2s;
  }
  .ai-contact-link:hover {
    color: #F4A7B9;
  }
</style>

<script>
  import { priceList, aiPromptTemplate } from '../data/prompts';

  // DOM Elements
  const toggleBtn = document.getElementById('ai-chat-toggle');
  const closeBtn = document.getElementById('ai-chat-close');
  const chatWindow = document.getElementById('ai-chat-window');
  const chatForm = document.getElementById('ai-chat-form');
  const chatInput = document.getElementById('ai-chat-input');
  const chatMessages = document.getElementById('ai-chat-messages');
  const thinkingIndicator = document.getElementById('ai-chat-thinking');

  // Toggle chat window
  const toggleChat = () => {
    chatWindow?.classList.toggle('hidden');
    chatWindow?.classList.toggle('flex');
    if (!chatWindow?.classList.contains('hidden')) {
      chatInput?.focus();
    }
  };

  toggleBtn?.addEventListener('click', () => {
    toggleChat();
    // チャット開閉に合わせて吹き出しを切り替え
    if (callout) {
      callout.style.display = chatWindow?.classList.contains('hidden') ? '' : 'none';
    }
  });
  closeBtn?.addEventListener('click', () => {
    toggleChat();
    // 閉じたとき吹き出しを再表示
    if (callout) callout.style.display = '';
  });

  // Auto-resize textarea
  chatInput?.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = (this.scrollHeight < 100 ? this.scrollHeight : 100) + 'px';
  });

  // Enter to submit (Shift+Enter for new line)
  chatInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      chatForm?.dispatchEvent(new Event('submit'));
    }
  });

  const SYSTEM_PROMPT = aiPromptTemplate.replace('{{PRICE_LIST}}', priceList);

  let messages = [
    { role: "system", content: SYSTEM_PROMPT }
  ];

  // Contactページへの連携ボタン処理
  const toContactBtn = document.getElementById('ai-chat-to-contact');
  toContactBtn?.addEventListener('click', () => {
    const chatLog = messages.filter(m => m.role !== 'system');
    if (chatLog.length === 0) {
      alert('まだ会話のやり取りがありません。まずはご相談ください！');
      return;
    }
    const historyText = chatLog.map(m => `[${m.role === 'user' ? 'あなた' : 'AI'}]\n${m.content}`).join('\n\n');
    sessionStorage.setItem('kinato_chat_history', historyText);
    window.location.href = '/contact?from_chat=1';
  });

  // 「お問い合わせよりDMください」をリンクに変換する関数
  const linkifyContact = (text) => {
    return text.replace(
      /お問い合わせよりDMください/g,
      '<a href="/contact" class="ai-contact-link" target="_self">お問い合わせよりDMください</a>'
    );
  };

  const appendMessage = (role, content) => {
    const msgDiv = document.createElement('div');
    msgDiv.className = `flex items-start gap-2 max-w-[85%] ${role === 'user' ? 'ml-auto flex-row-reverse' : ''}`;
    
    let avatarHTML = '';
    if (role === 'assistant') {
      // AIアバター：きなとさん顔画像
      avatarHTML = `
        <div class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0 border-2 border-pink-200 shadow-sm mt-1">
          <img src="/assets/characters/Gemini_Generated_Image_rhw0c8rhw0c8rhw0.png" alt="きなとさん" class="w-full h-full object-cover object-top" />
        </div>
      `;
    }

    // ユーザーバブル：グリーン、AIバブル：ホワイト
    const bubbleClass = role === 'user' 
      ? 'user-bubble p-3 rounded-2xl rounded-tr-sm text-sm shadow-sm leading-relaxed' 
      : 'bg-white p-3 rounded-2xl rounded-tl-sm text-sm text-[#5A544F] shadow-sm border border-[#F2E0D8] leading-relaxed';

    // AI回答のみリンク変換を適用
    const displayContent = role === 'assistant' ? linkifyContact(content) : content;

    msgDiv.innerHTML = `
      ${avatarHTML}
      <div class="${bubbleClass}" style="word-break: break-word; white-space: pre-wrap;">${displayContent}</div>
    `;

    chatMessages?.appendChild(msgDiv);
    
    // 最下部へスクロール
    if (chatMessages) {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
  };

  // チャットを閉じたとき吹き出しを表示、開いたとき非表示
  const callout = document.getElementById('chat-callout');
  const originalToggleChat = toggleChat;

  chatForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = chatInput?.value.trim();
    if (!message) return;

    // 入力リセット
    if (chatInput) {
      chatInput.value = '';
      chatInput.style.height = 'auto';
    }

    // ユーザーメッセージをUIに追加
    appendMessage('user', message);
    
    // 会話履歴に追加
    messages.push({ role: "user", content: message });

    // 考え中インジケーター表示
    thinkingIndicator?.classList.remove('hidden');

    // 最下部へスクロール
    if (chatMessages) chatMessages.scrollTop = chatMessages.scrollHeight;

    try {
      // Gemini v1 API形式にフォーマット（systemInstructionはv1では未対応のため先頭に埋め込む）
      const userMessages = messages.filter(m => m.role !== "system");
      const contents = [
        // システムプロンプトを最初のユーザー発言として埋め込む
        { role: "user", parts: [{ text: SYSTEM_PROMPT + "\n\n以上がシステム設定です。了解しましたか？" }] },
        { role: "model", parts: [{ text: "はい、了解しました。きなとのケージ屋さん相談AIとして、ケージや生き物に関するご相談にお答えします。" }] },
        // 実際の会話履歴
        ...userMessages.map(m => ({
          role: m.role === "assistant" ? "model" : "user",
          parts: [{ text: m.content }]
        }))
      ];

      // Google検索Groundingは一時的に無効化（クォータ確認のため）
      const geminiPayload = { contents };

      const response = await fetch("https://damp-grass-c643.kinatocage.workers.dev/", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(geminiPayload)
      });

      // レスポンスのテキストを先に取得してエラー内容を確認できるようにする
      const rawText = await response.text();
      let data;
      try {
        data = JSON.parse(rawText);
      } catch {
        throw new Error("サーバーから無効なレスポンスが返されました: " + rawText.slice(0, 100));
      }

      if (!response.ok) {
        // 429: クォータ超過（支払い反映待ち）
        if (response.status === 429) {
          throw new Error("QUOTA_EXCEEDED");
        }
        const msg = data?.error?.message || response.status + " " + response.statusText;
        throw new Error("APIエラー: " + msg);
      }

      let replyContent = "申し訳ありません。現在システムが混み合っているようです。";

      if (data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts) {
        replyContent = data.candidates[0].content.parts[0].text; // Gemini形式
      } else if (data.error && data.error.message) {
        // Geminiからのエラーレスポンス内の429チェック
        if (data.error.code === 429) {
          throw new Error("QUOTA_EXCEEDED");
        }
        throw new Error(data.error.message);
      } else if (typeof data === "string") {
        replyContent = data;
      }

      appendMessage('assistant', replyContent);
      messages.push({ role: "assistant", content: replyContent });

    } catch (error) {
      console.error("チャットエラー:", error);
      // 429クォータエラーは専用メッセージ
      if (error.message === "QUOTA_EXCEEDED") {
        appendMessage('assistant', "お支払い情報の反映を待っています。数分後に再度お試しください。");
      } else {
        appendMessage('assistant', "（エラー）" + (error.message || "不明なエラーが発生しました。"));
      }
    } finally {
      // 考え中インジケーターを隠す
      thinkingIndicator?.classList.add('hidden');
    }
  });
</script>
