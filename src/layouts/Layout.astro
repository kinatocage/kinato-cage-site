---
export interface Props {
	title: string;
}

const { title } = Astro.props;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-W5HMEDEZ4J';
---

<!doctype html>
<html lang="ja">
	<head>
		{/* Google tag (gtag.js) */}
		{gaId && (
			<>
				<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script is:inline set:html={`
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', '${gaId}');
				`}></script>
			</>
		)}
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Kiwi+Maru:wght@400;500&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="site-header">
			<div class="header-inner">
				<a href="/" class="site-title">
					<img src="/assets/logo/丸ロゴピンク.png" alt="きなとのケージ屋さん ロゴ" class="header-logo" />
					<span class="logo-text">きなとのケージ屋さん</span>
				</a>
			</div>
			<nav class="global-nav">
				<ul class="nav-list">
					<li><a href="/concept" class="nav-link">コンセプト</a></li>
				<li><a href="/#gallery" class="nav-link">作例紹介</a></li>
					<li><a href="/#types" class="nav-link">ケージの種類</a></li>
					<li><a href="/#works" class="nav-link">製作事例紹介</a></li>
					<li><a href="/options" class="nav-link">オプション類</a></li>
					<li><a href="/contact" class="nav-link">お問い合わせ</a></li>
					<li><a href="/legal" class="nav-link">特定商取引法に基づく表記</a></li>
				</ul>
			</nav>
		</header>
		<slot />
		<footer class="site-footer">
			<div class="footer-inner">
				<img src="/assets/logo/丸ロゴピンク.png" alt="ロゴ" class="footer-logo" />
				<p class="footer-copy">&copy; 2015-{new Date().getFullYear()} きなとのケージ屋さん All Rights Reserved.</p>
				<p class="footer-sub">🐾 ペットと暮らす、もっとおしゃれで優しい時間。</p>
				<div class="footer-qr">
					<img src="/QR.png" alt="QRコード" class="qr-image" />
					<span>https://kinato-cage-site.pages.dev/</span>
				</div>
			</div>
		</footer>

		<!-- 右下固定キャラクターウィジェット -->
		<div id="character-widget" class="char-widget">
			<div class="char-balloon">
				ご質問や要望、ご注文は<br />お問い合わせよりご連絡ください♪
			</div>
			<img src="/assets/characters/charactor2.png" alt="きなとちゃん" class="char-image" />
		</div>
	</body>
</html>

<style is:global>
	:root {
		/* カラーパレット：温かみのあるベージュ＋くすみグリーン＋ピンクアクセント */
		--color-bg: #FFF8F5;
		--color-surface: #FFFFFF;
		--color-surface-hover: #FFF1EC;
		--color-primary: #8A9A86;
		--color-primary-dark: #6B7E66;
		--color-primary-light: #C1CDC0;
		--color-text: #5A544F;
		--color-text-light: #9A8E88;
		--color-accent: #F4A7B9;
		--color-accent-warm: #F9C784;
		--color-border: #F2E0D8;
		--color-pink-light: #FDE8EE;

		/* 角丸 */
		--radius-sm: 10px;
		--radius-md: 18px;
		--radius-lg: 28px;
		--radius-full: 9999px;

		/* フォント */
		--font-base: 'Kiwi Maru', serif;
		--font-heading: 'Nunito', 'Kiwi Maru', sans-serif;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
		background-color: var(--color-bg);
		color: var(--color-text);
		font-family: var(--font-base);
		line-height: 1.6;
		scroll-behavior: smooth;
	}

	* {
		box-sizing: border-box;
	}

	h1, h2, h3, h4, p {
		margin: 0;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	ul, ol {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	img {
		max-width: 100%;
		height: auto;
		display: block;
	}

	/* ===== ヘッダー ===== */
	.site-header {
		background: linear-gradient(135deg, #FFFFFF 0%, #FFF4F7 100%);
		position: sticky;
		top: 0;
		z-index: 100;
		box-shadow: 0 2px 20px rgba(244, 167, 185, 0.15);
		border-bottom: 2px solid var(--color-pink-light);
	}

	.header-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0.75rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.site-title {
		font-family: var(--font-heading);
		font-size: 1.4rem;
		font-weight: 800;
		color: var(--color-primary-dark);
		display: flex;
		align-items: center;
		gap: 0.6rem;
		transition: opacity 0.2s;
	}

	.header-logo {
		width: 40px;
		height: 40px;
		object-fit: contain;
		border-radius: 50%;
	}

	.site-title:hover {
		opacity: 0.8;
	}

	/* ===== ナビゲーション ===== */
	.global-nav {
		background: transparent;
		overflow-x: auto;
		scrollbar-width: none;
	}

	.global-nav::-webkit-scrollbar {
		display: none;
	}

	.nav-list {
		display: flex;
		justify-content: center;
		align-items: center;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1rem;
		white-space: nowrap;
	}

	.nav-link {
		display: block;
		padding: 0.7rem 1.4rem;
		font-family: var(--font-heading);
		font-weight: 600;
		color: var(--color-text);
		font-size: 0.9rem;
		position: relative;
		transition: color 0.3s ease;
		border-radius: var(--radius-full);
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: 4px;
		left: 50%;
		transform: translateX(-50%);
		width: 0;
		height: 3px;
		background: linear-gradient(to right, var(--color-accent), var(--color-accent-warm));
		transition: width 0.3s ease;
		border-radius: 3px;
	}

	.nav-link:hover {
		color: var(--color-primary-dark);
	}

	.nav-link:hover::after {
		width: 70%;
	}

	@media (max-width: 768px) {
		.nav-list {
			justify-content: flex-start;
			padding: 0 0.5rem;
		}
		.nav-link {
			padding: 0.65rem 0.9rem;
			font-size: 0.85rem;
		}
		.logo-text {
			font-size: 1.1rem;
		}
	}

	/* ===== フッター ===== */
	.site-footer {
		background: linear-gradient(135deg, var(--color-primary) 0%, #7A9E75 100%);
		color: #fff;
		text-align: center;
		padding: 3rem 1.5rem;
		margin-top: 5rem;
	}

	.footer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
	}

	.footer-logo {
		width: 56px;
		height: 56px;
		object-fit: contain;
		border-radius: 50%;
		border: 3px solid rgba(255,255,255,0.5);
	}

	.footer-copy {
		font-size: 0.85rem;
		font-family: var(--font-heading);
		opacity: 0.9;
	}

	.footer-sub {
		font-size: 0.875rem;
		opacity: 0.75;
	}

	.footer-qr {
		margin-top: 1rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4rem;
	}

	.qr-image {
		width: 90px;
		height: 90px;
		border-radius: 8px;
		background: #fff;
		padding: 5px;
		box-shadow: 0 4px 10px rgba(0,0,0,0.1);
	}

	.footer-qr span {
		font-size: 0.75rem;
		opacity: 0.8;
		font-family: var(--font-heading);
	}

	/* ===== 共通レイアウト ===== */
	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.section {
		padding: 4rem 0;
	}

	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.section-header h2 {
		font-family: var(--font-heading);
		font-size: 1.9rem;
		color: var(--color-primary-dark);
		margin-bottom: 0.5rem;
		font-weight: 800;
	}

	.section-header p {
		color: var(--color-text-light);
		font-size: 0.95rem;
	}

	/* セクションタイトルのかわいいデコレーション */
	.section-header h2::before {
		content: '🌿 ';
	}
	.section-header h2::after {
		content: ' 🌿';
	}

	/* プレースホルダー */
	.placeholder-image {
		width: 100%;
		height: 100%;
		background-color: var(--color-surface-hover);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-text-light);
		font-weight: 600;
		font-family: var(--font-heading);
		font-size: 0.875rem;
		position: relative;
		overflow: hidden;
	}

	.placeholder-image::after {
		content: "";
		position: absolute;
		top: 0;
		left: -100%;
		width: 50%;
		height: 100%;
		background: linear-gradient(
			to right,
			rgba(255, 255, 255, 0) 0%,
			rgba(255, 255, 255, 0.6) 50%,
			rgba(255, 255, 255, 0) 100%
		);
		animation: shimmer 2s infinite;
	}

	@keyframes shimmer {
		100% { left: 200%; }
	}

	/* カード共通 */
	.card-base {
		background: var(--color-surface);
		border-radius: var(--radius-md);
		overflow: hidden;
		transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
		box-shadow: 0 4px 16px rgba(244, 167, 185, 0.08);
	}

	.card-base:hover {
		transform: translateY(-5px);
		box-shadow: 0 14px 30px rgba(244, 167, 185, 0.18);
	}

	/* ===== キャラクターウィジェット（右下固定） ===== */
	.char-widget {
		position: fixed;
		bottom: 1.5rem;
		right: 1.5rem;
		z-index: 1000;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.5rem;
		cursor: pointer;
	}

	/* 浮遊アニメーション */
	@keyframes float {
		0%   { transform: translateY(0px); }
		50%  { transform: translateY(-10px); }
		100% { transform: translateY(0px); }
	}

	.char-image {
		width: 80px;
		height: auto;
		filter: drop-shadow(0 6px 12px rgba(244, 167, 185, 0.4));
		animation: float 3s ease-in-out infinite;
		transition: transform 0.3s ease;
	}

	.char-widget:hover .char-image {
		animation-play-state: paused;
		transform: scale(1.1) rotate(-5deg);
	}

	/* 吹き出し */
	.char-balloon {
		background: white;
		border: 2px solid var(--color-accent);
		border-radius: var(--radius-md);
		padding: 0.65rem 1rem;
		font-size: 0.78rem;
		color: var(--color-text);
		font-family: var(--font-base);
		line-height: 1.6;
		box-shadow: 0 4px 16px rgba(244, 167, 185, 0.25);
		max-width: 200px;
		text-align: center;
		position: relative;
		/* 初期は非表示 → ホバーで表示 */
		opacity: 0;
		transform: translateY(8px) scale(0.95);
		transition: opacity 0.3s ease, transform 0.3s ease;
		pointer-events: none;
	}

	/* 吹き出しの三角 */
	.char-balloon::after {
		content: '';
		position: absolute;
		bottom: -12px;
		right: 28px;
		border-width: 10px 8px 0 8px;
		border-style: solid;
		border-color: white transparent transparent transparent;
		filter: drop-shadow(0 2px 0 var(--color-accent));
	}

	.char-widget:hover .char-balloon {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	@media (max-width: 768px) {
		.char-image {
			width: 64px;
		}
		.char-balloon {
			font-size: 0.72rem;
			max-width: 170px;
		}
	}
</style>
