---
import Layout from '../layouts/Layout.astro';
---

<Layout title="コンセプト | きなとのケージ屋さん">
  <main class="concept-page">

    <!-- ===== ヒーローセクション ===== -->
    <section class="concept-hero">
      <!-- 装飾バブル -->
      <div class="concept-bubble cb1"></div>
      <div class="concept-bubble cb2"></div>
      <div class="concept-bubble cb3"></div>
      <div class="concept-bubble cb4"></div>

      <div class="concept-hero-content">
        <div class="concept-hero-text">
          <p class="concept-hero-label">✨ Our Concept</p>
          <h1 class="concept-hero-title">
            飼い主様が求める<br />理想のケージ製作の<br class="sp-only" />お手伝いをさせて頂く
          </h1>
          <p class="concept-hero-subtitle">
            いのちが輝く、家族のための「最高の居場所」を。
          </p>
        </div>
        <div class="concept-hero-character">
          <div class="concept-hero-balloon">
            わたしがコンセプトを<br />ご案内するね♪
          </div>
          <img src="/assets/characters/charactor_contact.png" alt="きなとちゃん" class="concept-hero-char-img" />
        </div>
      </div>
    </section>

    <!-- ===== イントロメッセージ ===== -->
    <section class="concept-intro section">
      <div class="container">
        <div class="concept-intro-inner">
          <div class="concept-intro-text">
            <h2 class="concept-intro-heading">
              「もっとこうだったらいいのに」<br class="sp-only" />を形に。
            </h2>
            <p>
              市販のケージを使いながら、そんな風に思ったことはありませんか？
            </p>
            <p>
              大切な家族だからこそ、一番快適で、安全で、そして美しい場所に住まわせてあげたい。
            </p>
            <p>
              きなとのケージ屋さんは、アルミフレームという精密な素材と、数多くの生体と向き合ってきた経験から、
              あなたの「理想」をミリ単位で具現化します。
            </p>
          </div>
          <div class="concept-intro-char">
            <img src="/assets/characters/charactor_walk_nobg.png" alt="きなとちゃん" class="concept-intro-char-img" />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 3つの柱セクション ===== -->
    <section class="concept-pillars section">
      <div class="container">
        <div class="section-header">
          <h2>大切にしている3つのこと</h2>
          <p>きなとのケージ屋さんが胸に刻むこだわり</p>
        </div>

        <div class="pillars-grid">
          <!-- 柱1 -->
          <div class="pillar-card card-base">
            <div class="pillar-icon pillar-icon-green">
              🧬
            </div>
            <h3 class="pillar-title">生体ファーストの専門知識</h3>
            <p class="pillar-desc">
              動物取扱業としての知識に基づき、「その子」の習性に合わせた設計を提案。スロープの角度から換気効率まで、安全と快適を最優先します。
            </p>
            <div class="pillar-char-comment">
              <img src="/assets/characters/charactor2.png" alt="きなとちゃん" class="pillar-char-img" />
              <div class="pillar-balloon">
                その子の暮らしに<br />ぴったりをつくるよ♪
              </div>
            </div>
          </div>

          <!-- 柱2 -->
          <div class="pillar-card card-base">
            <div class="pillar-icon pillar-icon-pink">
              📐
            </div>
            <h3 class="pillar-title">ミリ単位の精密と調和</h3>
            <p class="pillar-desc">
              アルミフレームを採用し、スチールラックや棚の隙間に1mmの無駄なくフィット。デッドスペースを解消し、お部屋との調和を生み出します。
            </p>
            <div class="pillar-char-comment">
              <img src="/assets/characters/charactor2.png" alt="きなとちゃん" class="pillar-char-img" />
              <div class="pillar-balloon">
                ぴったりフィットが<br />気持ちいいの！
              </div>
            </div>
          </div>

          <!-- 柱3 -->
          <div class="pillar-card card-base">
            <div class="pillar-icon pillar-icon-amber">
              💡
            </div>
            <h3 class="pillar-title">魅せるための美学</h3>
            <p class="pillar-desc">
              ケージは生体が主役のステージ。視認性の高いアクリルや計算されたライティングにより、インテリアとしての機能美を追求します。
            </p>
            <div class="pillar-char-comment">
              <img src="/assets/characters/charactor2.png" alt="きなとちゃん" class="pillar-char-img" />
              <div class="pillar-balloon">
                おしゃれにしたい<br />気持ち、わかる〜❤️
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 爬虫類オーナー向け ===== -->
    <section class="concept-showcase section">
      <div class="container">
        <div class="showcase-row">
          <div class="showcase-text">
            <span class="showcase-tag">🦎 For Reptile Owners</span>
            <h2 class="showcase-title">爬虫類飼育の常識を変える</h2>
            <p class="showcase-desc">
              多頭飼育者のための「スタッキング（積み重ね）」、ボールパイソンのための「高断熱ポリカ」、生体を美しく見せる「フレームレスな視界」。爬虫類オーナー様が求める機能を、プロ仕様のクオリティで提供します。
            </p>
            <ul class="showcase-list">
              <li>
                <span class="check-icon">✅</span>
                マンションのような段積みが可能な強度
              </li>
              <li>
                <span class="check-icon">✅</span>
                アクリル、中空ポリカにより圧倒的な保温性
              </li>
              <li>
                <span class="check-icon">✅</span>
                アルミフレームを使い清潔感あるケージへ
              </li>
            </ul>
          </div>
          <div class="showcase-images">
            <div class="showcase-img-card card-base">
              <img src="/多段.png" alt="レオパマンション多段積みケージ" loading="lazy" />
            </div>
            <div class="showcase-img-card card-base">
              <img src="/black.png" alt="ブラックフレームのシックなケージ" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 小動物オーナー向け ===== -->
    <section class="concept-showcase concept-showcase-alt section">
      <div class="container">
        <div class="showcase-row showcase-row-reverse">
          <div class="showcase-images">
            <div class="showcase-img-card card-base">
              <img src="/TypeA2.JPG" alt="スチールラックにぴったりのハリネズミケージ" loading="lazy" />
            </div>
            <div class="showcase-img-card card-base">
              <img src="/TypeH.png" alt="二階建て構造のジリスケージ" loading="lazy" />
            </div>
          </div>
          <div class="showcase-text">
            <span class="showcase-tag showcase-tag-blue">🐿️ For Small Animals</span>
            <h2 class="showcase-title">「あと少し」の工夫を凝縮</h2>
            <p class="showcase-desc">
              ハリネズミ、ジリス、フクロモモンガ。活動的な彼らのための「安全な遊び場」をケージの中に。市販ラックのサイズに合わせた「シンデレラフィット」で、飼育環境をもっとスマートに。
            </p>
            <ul class="showcase-list">
              <li>
                <span class="check-icon check-blue">✅</span>
                お掃除が劇的に楽になる引き出し・扉構造
              </li>
              <li>
                <span class="check-icon check-blue">✅</span>
                生体の特性を理解したケガを防ぐ構造
              </li>
              <li>
                <span class="check-icon check-blue">✅</span>
                2階建て等の自由な立体空間設計
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== CTAセクション ===== -->
    <section class="concept-cta section">
      <div class="container">
        <div class="concept-cta-inner">
          <div class="concept-cta-text">
            <h2 class="concept-cta-title">あなたの「理想」を聞かせてください♪</h2>
            <p class="concept-cta-desc">
              私たちはただケージを作るのではなく、あなたの飼育ライフをより豊かにするためのパートナーでありたいと考えています。些細なご相談でも構いません。
            </p>
            <div class="concept-cta-buttons">
              <a href="/contact" class="concept-cta-btn concept-cta-btn-primary" id="concept-contact-btn">
                📩 お問い合わせはこちら
              </a>
              <a href="/#works" class="concept-cta-btn concept-cta-btn-secondary" id="concept-works-btn">
                🐾 製作事例を見る
              </a>
            </div>
          </div>
          <div class="concept-cta-char">
            <img src="/assets/characters/charactor2.png" alt="きなとちゃん" class="concept-cta-char-img" />
            <div class="concept-cta-balloon">
              お気軽にどうぞ〜！<br />一緒に考えようね♪
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* ===== コンセプトページ全体 ===== */
  .concept-page {
    overflow-x: hidden;
  }

  /* ===== ヒーロー ===== */
  .concept-hero {
    position: relative;
    padding: 4rem 1.5rem 5rem;
    text-align: center;
    overflow: hidden;
    background: linear-gradient(160deg, #FFF8F5 0%, #FDE8EE 35%, #FFF4E6 70%, #E8F5E9 100%);
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* 装飾バブル */
  .concept-bubble {
    position: absolute;
    border-radius: 50%;
    opacity: 0.15;
    pointer-events: none;
  }
  .cb1 {
    width: 280px; height: 280px;
    background: var(--color-accent);
    top: -60px; left: -60px;
    animation: concept-float 9s ease-in-out infinite;
  }
  .cb2 {
    width: 200px; height: 200px;
    background: var(--color-accent-warm);
    bottom: -40px; right: -30px;
    animation: concept-float 11s ease-in-out infinite reverse;
  }
  .cb3 {
    width: 120px; height: 120px;
    background: var(--color-primary-light);
    top: 20%; right: 15%;
    animation: concept-float 7s ease-in-out infinite 1.5s;
  }
  .cb4 {
    width: 90px; height: 90px;
    background: var(--color-accent);
    bottom: 25%; left: 10%;
    animation: concept-float 8s ease-in-out infinite 3s;
  }

  @keyframes concept-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(15px, -20px) scale(1.05); }
  }

  .concept-hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .concept-hero-text {
    flex: 1;
    text-align: left;
  }

  .concept-hero-label {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    color: var(--color-accent);
    font-weight: 700;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    display: inline-block;
    background: white;
    padding: 0.3rem 1rem;
    border-radius: var(--radius-full);
    box-shadow: 0 3px 12px rgba(244, 167, 185, 0.2);
  }

  .concept-hero-title {
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    line-height: 1.5;
    margin-bottom: 1.2rem;
    font-family: var(--font-heading);
  }

  .concept-hero-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  /* ヒーローキャラクター */
  .concept-hero-character {
    flex-shrink: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .concept-hero-char-img {
    width: 180px;
    height: auto;
    filter: drop-shadow(0 10px 24px rgba(244, 167, 185, 0.3));
    animation: hero-bounce 3s ease-in-out infinite;
  }

  .concept-hero-balloon {
    background: white;
    border: 2px solid var(--color-accent);
    border-radius: var(--radius-md);
    padding: 0.6rem 1rem;
    font-size: 0.82rem;
    color: var(--color-text);
    line-height: 1.6;
    box-shadow: 0 4px 16px rgba(244, 167, 185, 0.25);
    text-align: center;
    position: relative;
    margin-bottom: 0.6rem;
    animation: balloon-fade 3s ease-in-out infinite;
  }

  .concept-hero-balloon::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    border-width: 10px 8px 0 8px;
    border-style: solid;
    border-color: white transparent transparent transparent;
    filter: drop-shadow(0 2px 0 var(--color-accent));
  }

  @keyframes hero-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @keyframes balloon-fade {
    0%, 100% { opacity: 1; transform: translateY(0); }
    50% { opacity: 0.85; transform: translateY(-5px); }
  }

  .sp-only { display: none; }

  @media (max-width: 768px) {
    .sp-only { display: inline; }
    .concept-hero { padding: 3rem 1.5rem 4rem; min-height: auto; }
    .concept-hero-content {
      flex-direction: column;
      text-align: center;
    }
    .concept-hero-text { text-align: center; }
    .concept-hero-title { font-size: 1.6rem; }
    .concept-hero-char-img { width: 130px; }
  }

  /* ===== イントロセクション ===== */
  .concept-intro {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    margin: -2rem 1rem 0;
    position: relative;
    z-index: 2;
    box-shadow: 0 8px 40px rgba(244, 167, 185, 0.1);
  }

  .concept-intro-inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 3rem 2rem;
  }

  .concept-intro-text {
    flex: 1;
  }

  .concept-intro-heading {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--color-primary-dark);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .concept-intro-text p {
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.9;
    margin-bottom: 0.8rem;
  }

  .concept-intro-char {
    flex-shrink: 0;
  }

  .concept-intro-char-img {
    width: 120px;
    height: auto;
    filter: drop-shadow(0 6px 16px rgba(244, 167, 185, 0.3));
    animation: hero-bounce 4s ease-in-out infinite;
  }

  @media (max-width: 768px) {
    .concept-intro {
      margin: -1.5rem 0.5rem 0;
    }
    .concept-intro-inner {
      flex-direction: column;
      padding: 2rem 1.5rem;
      text-align: center;
    }
    .concept-intro-heading { font-size: 1.4rem; }
    .concept-intro-char-img { width: 90px; }
  }

  /* ===== 3つの柱セクション ===== */
  .concept-pillars {
    background: linear-gradient(180deg, var(--color-bg) 0%, #FDE8EE22 100%);
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .pillar-card {
    padding: 2.5rem 1.8rem 1.5rem;
    text-align: center;
    position: relative;
    border: 2px solid transparent;
    transition: border-color 0.3s ease, transform 0.4s ease;
  }

  .pillar-card:hover {
    border-color: var(--color-accent);
  }

  .pillar-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.2rem;
    font-size: 1.6rem;
    transition: transform 0.3s ease;
  }

  .pillar-card:hover .pillar-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .pillar-icon-green {
    background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  }
  .pillar-icon-pink {
    background: linear-gradient(135deg, var(--color-pink-light), #F8BBD0);
  }
  .pillar-icon-amber {
    background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  }

  .pillar-title {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--color-primary-dark);
    font-weight: 700;
    margin-bottom: 0.8rem;
  }

  .pillar-desc {
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  /* 柱カード内キャラクターコメント */
  .pillar-char-comment {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    justify-content: center;
    margin-top: auto;
  }

  .pillar-char-img {
    width: 45px;
    height: auto;
    filter: drop-shadow(0 3px 8px rgba(244, 167, 185, 0.3));
  }

  .pillar-balloon {
    background: var(--color-pink-light);
    border: 1.5px dashed var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.7rem;
    font-size: 0.72rem;
    color: var(--color-text);
    line-height: 1.5;
    text-align: left;
    position: relative;
  }

  .pillar-balloon::before {
    content: '';
    position: absolute;
    left: -8px;
    bottom: 8px;
    border-width: 6px 8px 6px 0;
    border-style: solid;
    border-color: transparent var(--color-pink-light) transparent transparent;
  }

  @media (max-width: 768px) {
    .pillars-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .pillar-card { padding: 2rem 1.5rem 1.5rem; }
  }

  /* ===== ショーケースセクション共通 ===== */
  .concept-showcase {
    padding: 4rem 0;
  }

  .concept-showcase-alt {
    background: linear-gradient(180deg, #FDE8EE11 0%, var(--color-bg) 100%);
  }

  .showcase-row {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .showcase-row-reverse {
    flex-direction: row-reverse;
  }

  .showcase-text {
    flex: 1;
  }

  .showcase-tag {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin-bottom: 1rem;
    font-family: var(--font-heading);
  }

  .showcase-tag-blue {
    background: linear-gradient(135deg, #E3F2FD, #BBDEFB);
  }

  .showcase-title {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--color-primary-dark);
    font-weight: 800;
    margin-bottom: 1.2rem;
    line-height: 1.4;
  }

  .showcase-desc {
    font-size: 0.92rem;
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .showcase-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .showcase-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text);
    padding: 0.5rem 0.8rem;
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .showcase-list li:hover {
    transform: translateX(5px);
    box-shadow: 0 4px 12px rgba(244, 167, 185, 0.15);
  }

  .check-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }

  /* ショーケース画像 */
  .showcase-images {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .showcase-img-card {
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 1 / 1;
    background: #f7f7f7;
  }

  .showcase-img-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    filter: brightness(1.02) saturate(1.05);
  }

  .showcase-img-card:hover img {
    transform: scale(1.06);
  }

  @media (max-width: 768px) {
    .showcase-row,
    .showcase-row-reverse {
      flex-direction: column;
    }
    .showcase-title { font-size: 1.4rem; }
    .showcase-images {
      width: 100%;
      gap: 0.8rem;
    }
  }

  /* ===== CTAセクション ===== */
  .concept-cta {
    background: linear-gradient(135deg, var(--color-primary) 0%, #7A9E75 60%, #6B8E62 100%);
    border-radius: var(--radius-lg);
    margin: 0 1rem;
    position: relative;
    overflow: hidden;
  }

  .concept-cta::before {
    content: '';
    position: absolute;
    top: -50px;
    right: -50px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    pointer-events: none;
  }

  .concept-cta::after {
    content: '';
    position: absolute;
    bottom: -30px;
    left: -30px;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    pointer-events: none;
  }

  .concept-cta-inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    position: relative;
    z-index: 1;
    padding: 1rem 0;
  }

