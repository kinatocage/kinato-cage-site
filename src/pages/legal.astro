---
import Layout from '../layouts/Layout.astro';
---

<Layout title="特定商取引法に基づく表記 | きなとのケージ屋さん">
	<main class="container">
		<section class="section">
			<div class="section-header">
				<h1>特定商取引法に基づく表記</h1>
				<p>Legal Notice</p>
			</div>
			
			<div class="legal-image-container card-base">
				<img 
					src="/特定商取引法に基づく表記（住所無し）.jpg" 
					alt="特定商取引法に基づく表記" 
					class="legal-image"
				/>
			</div>

			<div class="back-link-container">
				<a href="/" class="back-link">トップページに戻る</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.section-header h1 {
		font-family: var(--font-heading);
		font-size: 2rem;
		color: var(--color-primary-dark);
		margin-bottom: 0.5rem;
		font-weight: 800;
	}

	.section-header p {
		color: var(--color-text-light);
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.legal-image-container {
		background: white;
		padding: 2rem;
		display: flex;
		justify-content: center;
		align-items: center;
		box-shadow: 0 10px 30px rgba(0,0,0,0.05);
	}

	.legal-image {
		width: 100%;
		height: auto;
		max-width: 800px;
		border: 1px solid var(--color-border);
	}

	.back-link-container {
		margin-top: 3rem;
		text-align: center;
	}

	.back-link {
		display: inline-block;
		padding: 0.8rem 2rem;
		background-color: var(--color-primary);
		color: white;
		border-radius: var(--radius-full);
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.back-link:hover {
		background-color: var(--color-primary-dark);
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(138, 154, 134, 0.3);
	}

	@media (max-width: 768px) {
		.legal-image-container {
			padding: 1rem;
		}
		.section-header h1 {
			font-size: 1.5rem;
		}
	}
</style>
