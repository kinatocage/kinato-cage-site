    .concept-banner-char-img { width: 75px; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const track = document.querySelector('.gallery-marquee-track');
    if (!track) return;

    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    let animationId = 0;
    let isHovering = false;

    // スクロール速度 (ピクセル/フレーム)
    const autoScrollSpeed = 0.5;

    const autoScroll = () => {
      // ユーザーがドラッグ中・タッチ中・ホバー中ではない場合のみ自動スクロール
      if (!isDown && !isHovering) {
        track.scrollLeft += autoScrollSpeed;
        
        // ギャラリーの画像リストは2セット（同じもの）並んでいる前提
        // 1セット目(全体の半分)をスクロールし終えたら、scrollLeftを0にリセットしてループさせる
        if (track.scrollLeft >= track.scrollWidth / 2) {
          track.scrollLeft -= track.scrollWidth / 2;
        } else if (track.scrollLeft <= 0 && autoScrollSpeed < 0) { 
          // もし逆にスクロールした場合の処理(念の為)
          track.scrollLeft += track.scrollWidth / 2;
        }
      }
      animationId = requestAnimationFrame(autoScroll);
    };

    animationId = requestAnimationFrame(autoScroll);

    // ホバー・タッチで一時停止
    track.addEventListener('mouseenter', () => isHovering = true);
    track.addEventListener('mouseleave', () => {
      isHovering = false;
      isDown = false;
      track.classList.remove('active');
    });
    track.addEventListener('touchstart', () => isHovering = true, { passive: true });
    track.addEventListener('touchend', () => isHovering = false);

    // マウスドラッグで横スクロール
    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.classList.add('active');
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    track.addEventListener('mouseup', () => {
      isDown = false;
      track.classList.remove('active');
    });

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5; // スクロール感度
      track.scrollLeft = scrollLeft - walk;
    });
  });
</script>