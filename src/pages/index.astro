---
import Layout from '../layouts/Layout.astro';
import { getTypes, getWorks } from '../lib/microcms';

// データの取得 (エラーハンドリングを追加してローカルテストしやすくする)
let types: any[] = [];
let works: any[] = [];

try {
  const typesResponse = await getTypes({ limit: 10 });
  types = typesResponse.contents || [];
  
  const worksResponse = await getWorks({ limit: 6 });
  works = worksResponse.contents || [];
} catch (err) {
  console.error("データの取得に失敗しました。スキーマやAPIキーを確認してください:", err);
}
---

<Layout title="きなとのケージ屋さん - ペットに優しいおしゃれなケージ">
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg" style="background-image: url('/assets/hero_interior.png'); mix-blend-mode: multiply; opacity: 0.15; z-index: 0;"></div>
      <div class="hero-content">
        <h1 class="hero-title">
          ペットと暮らす、<br />
          もっとおしゃれで<br class="sp-only" />優しい時間。
        </h1>
        <p class="hero-subtitle">インテリアに溶け込む、爬虫類・小動物のためのオーダーメイドケージ</p>
        <a href="#types" class="btn-primary">ケージの種類を見る</a>
      </div>
    </section>

    <!-- Types Section -->
    <section id="types" class="container section">
      <div class="section-header">
        <h2>Cage Types</h2>
        <p>お部屋の雰囲気や生体に合わせて選べるバリエーション</p>
      </div>
      
      {types.length > 0 ? (
        <div class="types-grid">
          {types.map(type => (
            <a href={`/types/${type.id}`} class="type-card card-base">
              <div class="type-image-wrapper">
                {type.image && type.image.length > 0 ? (
                  <img src={type.image[0].url} alt={type.title} class="type-image" loading="lazy" />
                ) : (
                  <img src="/assets/acrylic_cage.png" alt="No image available" class="type-image placeholder-fallback" loading="lazy" />
                )}
                <div class="type-overlay">
                  <span class="view-more">詳しく見る →</span>
                </div>
              </div>
              <div class="type-content">
                <h3>{type.title}</h3>
                <p>{type.description}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-state">Typeデータがありません。microCMSで入稿してください。</p>
      )}
    </section>

    <!-- Works Section -->
    <section id="works" class="section works-section">
      <div class="container">
        <div class="section-header">
          <h2>製作事例紹介</h2>
          <p>お客様の想いを形にした、世界に一つのケージたち</p>
        </div>

        {works.length > 0 ? (
          <div class="works-grid">
            {works.map(work => (
              <article class="work-card card-base">
                <div class="work-image-wrapper">
                  {work.images && work.images.length > 0 ? (
                    <img src={work.images[0].url} alt={work.title} class="work-image" loading="lazy" />
                  ) : (
                    <div class="placeholder-image" aria-label="画像読み込み中"></div>
                  )}
                  {work.cageType && (
                    <span class="badge type-badge">{work.cageType.title}</span>
                  )}
                </div>
                <div class="work-content">
                  <h3 class="work-title">{work.title}</h3>
                  <div class="work-meta">
                    {work.species && (
                      <span class="badge species-badge">
                        {Array.isArray(work.species) ? work.species.join(', ') : work.species}
                      </span>
                    )}
                  </div>
                  {work.customerComment && (
                    <div class="customer-voice">
                      <div class="voice-icon">💬</div>
                      <p class="voice-text">{work.customerComment}</p>
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="empty-state">製作事例がありません。</p>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  /* --- Hero Session --- */
  .hero {
    position: relative;
    padding: 6rem 1.5rem;
    text-align: center;
    overflow: hidden;
    background-color: var(--color-surface);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    box-shadow: 0 10px 30px rgba(138, 154, 134, 0.05);
    margin-bottom: 3rem;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    line-height: 1.4;
    margin-bottom: 1.5rem;
    font-family: var(--font-heading);
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-light);
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    display: inline-block;
    background-color: var(--color-primary);
    color: white;
    padding: 1rem 2.5rem;
    border-radius: var(--radius-full);
    font-weight: bold;
    font-size: 1.125rem;
    box-shadow: 0 4px 15px rgba(138, 154, 134, 0.3);
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background-color: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(138, 154, 134, 0.4);
  }

  .sp-only {
    display: none;
  }

  @media (max-width: 768px) {
    .sp-only { display: block; }
    .hero-title { font-size: 1.75rem; }
    .hero { padding: 4rem 1.5rem; }
  }

  /* --- Types Grid --- */
  .types-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .type-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    /* card-base で基本のshadowとtransitionを管理しているため個別指定は最小限に */
    border: 2px solid transparent;
  }

  .type-card:hover {
    border-color: var(--color-primary-light);
  }

  .type-image-wrapper {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .type-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .type-card:hover .type-image {
    transform: scale(1.05);
  }

  .type-overlay {
    position: absolute;
    inset: 0;
    background: rgba(107, 126, 102, 0.2); /* primary-dark 色の半透明 */
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .type-card:hover .type-overlay {
    opacity: 1;
  }

  .view-more {
    background: var(--color-surface);
    color: var(--color-primary-dark);
    padding: 0.5rem 1.5rem;
    border-radius: var(--radius-full);
    font-weight: bold;
    transform: translateY(10px);
    transition: transform 0.3s ease;
  }

  .type-card:hover .view-more {
    transform: translateY(0);
  }

  .type-content {
    padding: 1.5rem;
  }

  .type-content h3 {
    font-size: 1.25rem;
    color: var(--color-primary-dark);
    margin-bottom: 0.5rem;
    font-family: var(--font-heading);
  }

  .type-content p {
    font-size: 0.875rem;
    color: var(--color-text-light);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* --- Works Grid --- */
  .works-section {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    margin: 0 1rem;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
  }

  .work-image-wrapper {
    position: relative;
    aspect-ratio: 16/9;
  }

  .work-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .badge {
    position: absolute;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: bold;
    z-index: 10;
  }

  .type-badge {
    top: 1rem;
    right: 1rem;
    background-color: var(--color-surface);
    color: var(--color-primary-dark);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .species-badge {
    position: static;
    display: inline-block;
    background-color: var(--color-accent);
    color: white;
    margin-bottom: 0.5rem;
  }

  .work-content {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .work-title {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-heading);
    color: var(--color-text);
  }

  .customer-voice {
    margin-top: auto;
    background-color: var(--color-surface);
    padding: 1rem;
    border-radius: var(--radius-sm);
    display: flex;
    gap: 0.5rem;
    border: 1px dashed var(--color-border);
  }

  .voice-icon {
    font-size: 1.25rem;
  }

  .voice-text {
    font-size: 0.875rem;
    color: var(--color-text-light);
    font-style: italic;
    margin: 0;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-light);
    padding: 3rem;
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border: 2px dashed var(--color-border);
  }
</style>