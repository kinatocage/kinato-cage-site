---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/microcms';

// SSRモード: URLパラメータからIDを取得し、APIへ直接問い合わせる
const { id } = Astro.params;

let work: any = null;

try {
  // 指定IDのWorkデータを取得
  work = await client.get({ endpoint: 'works', contentId: id as string });
} catch (err) {
  console.error("Workデータの取得に失敗しました:", err);
  return Astro.redirect('/');
}
---

<Layout title={`${work.title} | 製作事例 | きなとのケージ屋さん`}>
  <main class="work-detail-page">
    <section class="work-hero">
      <div class="container">
        <div class="hero-inner">
          <div class="hero-image-col">
            {work.images && work.images.length > 0 ? (
              <img src={work.images[0].url} alt={work.title} class="hero-image" />
            ) : (
              <div class="placeholder-image hero-placeholder" aria-label="画像なし"></div>
            )}
            
            {/* 複数画像がある場合のギャラリー */}
            {work.images && work.images.length > 1 && (
              <div class="image-gallery">
                {work.images.slice(1).map((img: any) => (
                  <img src={img.url} alt={`${work.title}の画像`} class="gallery-thumb" loading="lazy" />
                ))}
              </div>
            )}
          </div>
          
          <div class="hero-text-col">
            <a href="/#works" class="back-link">← 製作事例一覧へ戻る</a>
            
            <div class="work-meta-top">
              {work.cageType && (
                <a href={`/types/${work.cageType.id}`} class="badge type-badge">{work.cageType.title}</a>
              )}
              {work.species && (
                <span class="badge species-badge">
                  {Array.isArray(work.species) ? work.species.join(', ') : work.species}
                </span>
              )}
            </div>

            <h1 class="work-title">{work.title}</h1>
            
            {work.size && (
              <div class="work-size">
                <span class="size-label">サイズ:</span>
                <span class="size-value">{work.size}</span>
              </div>
            )}

            {work.features && (
              <div class="work-features-box">
                <h3>主な特徴</h3>
                <p>{work.features}</p>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- 事例の詳細本文（リッチエディタ内容） -->
    {work.content && (
      <section class="section work-content-section">
        <div class="container">
          <div class="content-body" set:html={work.content}></div>
        </div>
      </section>
    )}

    <!-- お客様の声 -->
    {work.customerComment && (
      <section class="section customer-voice-section">
        <div class="container">
          <div class="section-header">
            <h2>お客様の声</h2>
          </div>
          <div class="customer-voice-box">
            <div class="voice-icon">💬</div>
            <p class="voice-text">{work.customerComment}</p>
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .work-detail-page {
    background-color: var(--color-bg);
  }

  .work-hero {
    background-color: var(--color-surface);
    padding: 3rem 0;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    box-shadow: 0 4px 20px rgba(138, 154, 134, 0.05);
    margin-bottom: 3rem;
  }

  .hero-inner {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .hero-image-col {
    flex: 1;
    max-width: 50%;
  }

  .hero-image {
    width: 100%;
    border-radius: var(--radius-md);
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    margin-bottom: 1rem;
    aspect-ratio: 16/9;
    object-fit: contain;
    background-color: #f7f7f7;
  }

  .hero-placeholder {
    aspect-ratio: 16/9;
    border-radius: var(--radius-md);
    background-color: #f0f0f0;
    margin-bottom: 1rem;
  }

  .image-gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .gallery-thumb {
    width:calc(33.333% - 0.35rem);
    aspect-ratio: 16/9;
    object-fit: contain;
    background-color: #f7f7f7;
    border-radius: var(--radius-sm);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .hero-text-col {
    flex: 1;
  }

  .back-link {
    display: inline-block;
    color: var(--color-primary);
    font-weight: bold;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .work-meta-top {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .badge {
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: bold;
    display: inline-block;
  }

  .type-badge {
    background-color: white;
    color: var(--color-primary-dark);
    border: 1px solid var(--color-primary-light);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .type-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .species-badge {
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-warm));
    color: white;
  }

  .work-title {
    font-size: 2.2rem;
    font-family: var(--font-heading);
    color: var(--color-primary-dark);
    margin-bottom: 1.5rem;
  }

  .work-size {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    padding: 0.5rem 1rem;
    background-color: rgba(232, 178, 126, 0.15); /* accent light */
    border-radius: var(--radius-sm);
    display: inline-block;
    color: var(--color-text);
  }

  .size-label {
    font-weight: bold;
    margin-right: 0.5rem;
  }

  .work-features-box {
    margin-top: 1rem;
    padding: 1.5rem;
    background-color: white;
    border-radius: var(--radius-md);
    border: 1px dashed var(--color-border);
  }

  .work-features-box h3 {
    font-size: 1.2rem;
    font-family: var(--font-heading);
    color: var(--color-primary-dark);
    margin-bottom: 0.8rem;
  }

  .work-features-box p {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.6;
    white-space: pre-wrap;
  }

  @media (max-width: 768px) {
    .hero-inner {
      flex-direction: column;
      gap: 2rem;
    }
    .hero-image-col {
      max-width: 100%;
    }
    .work-title {
      font-size: 1.8rem;
    }
  }

  /* Content Body (Rich Text) */
  .work-content-section {
    padding: 2rem 0;
  }

  .content-body {
    background-color: white;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: 0 2px 15px rgba(0,0,0,0.03);
    color: var(--color-text);
    line-height: 1.8;
  }

  .content-body h1, .content-body h2, .content-body h3 {
    font-family: var(--font-heading);
    color: var(--color-primary-dark);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .content-body h2 {
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.5rem;
  }

  .content-body p {
    margin-bottom: 1.5rem;
  }

  .content-body img {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
    margin: 1.5rem 0;
  }

  /* Customer Voice */
  .customer-voice-section {
    padding: 1rem 0 4rem;
  }

  .customer-voice-box {
    background: var(--color-pink-light);
    padding: 2rem;
    border-radius: var(--radius-md);
    display: flex;
    gap: 1.5rem;
    border: 2px dashed var(--color-accent);
    align-items: flex-start;
  }

  .voice-icon {
    font-size: 2.5rem;
  }

  .voice-text {
    font-size: 1.1rem;
    color: var(--color-text-dark);
    font-style: italic;
    margin: 0;
    line-height: 1.8;
    white-space: pre-wrap;
  }
</style>
