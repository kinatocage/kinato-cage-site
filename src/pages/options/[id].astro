---
import Layout from '../../layouts/Layout.astro';
import { client } from '../../lib/microcms';

// SSRモード: URLパラメータからIDを取得し、APIへ直接問い合わせる
const { id } = Astro.params;

let option: any = null;

try {
  // 指定IDのOptionデータを取得
  option = await client.get({ endpoint: 'options', contentId: id as string });
} catch (err) {
  console.error("Optionデータの取得に失敗しました:", err);
  return Astro.redirect('/options'); // 見つからない場合は一覧へ戻す
}
---

<Layout title={`${option.name} | オプション詳細 | きなとのケージ屋さん`}>
  <main class="option-detail-page">
    <section class="option-hero">
      <div class="container">
        <div class="hero-inner">
          <div class="hero-image-col">
            {option.images && option.images.length > 0 ? (
              <img src={option.images[0].url} alt={option.name} class="hero-image" />
            ) : (
              <div class="placeholder-image hero-placeholder" aria-label="画像なし"></div>
            )}
            
            {/* 複数画像がある場合のギャラリー */}
            {option.images && option.images.length > 1 && (
              <div class="image-gallery">
                {option.images.slice(1).map((img: any) => (
                  <img src={img.url} alt={`${option.name}の画像`} class="gallery-thumb" loading="lazy" />
                ))}
              </div>
            )}
          </div>
          
          <div class="hero-text-col">
            <a href="/options" class="back-link">← オプション一覧へ戻る</a>
            
            <div class="option-meta-top">
              {option.category && (
                <span class="badge category-badge">{option.category}</span>
              )}
            </div>

            <h1 class="option-title">{option.name}</h1>
            
            <div class="option-price-box">
              <span class="price-label">追加料金:</span>
              <span class="price-value">
                {option.price ? `+ ¥${Number(option.price).toLocaleString()}` : "サイズにより変動（お見積もり）"}
              </span>
            </div>

            <div class="applicable-types-box">
              <h3 class="types-heading">適用可能なケージタイプ</h3>
              <div class="applicable-types">
                {option.applicableTypes && option.applicableTypes.length > 0 ? (
                  option.applicableTypes.map((type: any) => (
                    <a href={`/types/${type.id}`} class="badge type-badge">{type.title}</a>
                  ))
                ) : (
                  <span class="badge common-badge">全ケージ共通</span>
                )}
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- オプションの詳細本文 -->
    {option.details && (
      <section class="section option-content-section">
        <div class="container">
          <div class="section-header">
            <h2>機能や効果の詳細</h2>
          </div>
          <div class="content-body">
            <p>{option.details}</p>
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .option-detail-page {
    background-color: var(--color-bg);
  }

  .option-hero {
    background-color: var(--color-surface);
    padding: 3rem 0;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    box-shadow: 0 4px 20px rgba(138, 154, 134, 0.05);
    margin-bottom: 3rem;
  }

  .hero-inner {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .hero-image-col {
    flex: 1;
    max-width: 50%;
  }

  .hero-image {
    width: 100%;
    border-radius: var(--radius-md);
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    margin-bottom: 1rem;
    aspect-ratio: 16/9;
    object-fit: contain;
    background-color: #f7f7f7;
  }

  .hero-placeholder {
    aspect-ratio: 16/9;
    border-radius: var(--radius-md);
    background-color: #f0f0f0;
    margin-bottom: 1rem;
  }

  .image-gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .gallery-thumb {
    width: calc(33.333% - 0.35rem);
    aspect-ratio: 16/9;
    object-fit: contain;
    background-color: #f7f7f7;
    border-radius: var(--radius-sm);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .hero-text-col {
    flex: 1;
  }

  .back-link {
    display: inline-block;
    color: var(--color-primary);
    font-weight: bold;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  .option-meta-top {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .badge {
    padding: 0.4rem 0.8rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: bold;
    display: inline-block;
  }

  .category-badge {
    background-color: var(--color-accent);
    color: white;
  }

  .option-title {
    font-size: 2.2rem;
    font-family: var(--font-heading);
    color: var(--color-primary-dark);
    margin-bottom: 1.5rem;
  }

  .option-price-box {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.5rem;
    background-color: rgba(232, 178, 126, 0.15); /* accent light */
    border-radius: var(--radius-sm);
    display: inline-block;
    color: var(--color-text);
  }

  .price-label {
    font-weight: bold;
    margin-right: 0.5rem;
  }
  
  .price-value {
    color: var(--color-accent);
    font-weight: bold;
    font-size: 1.25rem;
  }

  .applicable-types-box {
    margin-top: 1rem;
    padding: 1.5rem;
    background-color: white;
    border-radius: var(--radius-md);
    border: 1px dashed var(--color-border);
  }

  .types-heading {
    font-size: 1rem;
    font-family: var(--font-heading);
    color: var(--color-primary-dark);
    margin-bottom: 0.8rem;
  }

  .applicable-types {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .type-badge {
    background-color: white;
    color: var(--color-primary-dark);
    border: 1px solid var(--color-primary-light);
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .type-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .common-badge {
    background-color: rgba(138, 154, 134, 0.15);
    color: var(--color-primary-dark);
  }

  @media (max-width: 768px) {
    .hero-inner {
      flex-direction: column;
      gap: 2rem;
    }
    .hero-image-col {
      max-width: 100%;
    }
    .option-title {
      font-size: 1.8rem;
    }
  }

  /* Content Body */
  .option-content-section {
    padding: 1rem 0 4rem;
  }

  .content-body {
    background-color: white;
    padding: 2.5rem;
    border-radius: var(--radius-lg);
    box-shadow: 0 2px 15px rgba(0,0,0,0.03);
    color: var(--color-text);
    line-height: 1.8;
  }

  .content-body p {
    font-size: 1rem;
    white-space: pre-wrap;
    margin: 0;
  }
</style>
